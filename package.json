{
  "name": "webbooks-theme-build",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "preflight:node": "node scripts/check-node-version.js",
    "i18n:update": "bash scripts/update-i18n.sh",
    "build": "bash scripts/build-with-fallback.sh",
    "build:local": "vite build",
    "ci:build": "npm run preflight:node && npm ci && npm run build:local",
    "release:prepare": "bash scripts/build-release.sh",
    "theme": "bash scripts/theme-release.sh"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  }
}
